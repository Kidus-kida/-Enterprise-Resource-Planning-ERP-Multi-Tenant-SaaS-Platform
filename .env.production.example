# Production Environment Configuration
# Copy this file to .env and modify values as needed

APP_NAME="TewosHR"
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_TIMEZONE=UTC
APP_URL=https://your-domain.com

# Logging - use single file in production
LOG_CHANNEL=single
LOG_STACK=single
LOG_LEVEL=error

# Database Configuration
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=your_database
DB_USERNAME=your_username
DB_PASSWORD=your_password

# Session & Cache - use file or redis for performance
# File driver is faster than database for most use cases
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=true

# Cache Configuration - file is faster than database
# Use redis for distributed systems or high-traffic apps
CACHE_STORE=file

# Queue Configuration
QUEUE_CONNECTION=database

# Redis (optional - uncomment if using Redis for cache/sessions)
# REDIS_HOST=127.0.0.1
# REDIS_PASSWORD=null
# REDIS_PORT=6379
# CACHE_STORE=redis
# SESSION_DRIVER=redis

# Mail Configuration
MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Broadcasting (optional)
BROADCAST_CONNECTION=log

# Filesystem
FILESYSTEM_DISK=local

# =================================================
# PERFORMANCE OPTIMIZATION CHECKLIST
# =================================================
# After deploying, run these commands:
#
# 1. Cache configuration:
#    php artisan config:cache
#
# 2. Cache routes:
#    php artisan route:cache
#
# 3. Cache views:
#    php artisan view:cache
#
# 4. Optimize autoloader:
#    composer dump-autoload -o
#
# 5. Run Laravel optimize:
#    php artisan optimize
#
# 6. Run database migrations (includes indexes):
#    php artisan migrate --force
#
# 7. Build frontend assets:
#    npm run build
#
# =================================================
# PHP.INI RECOMMENDATIONS (OPcache)
# =================================================
# Add these to your php.ini for production:
#
# opcache.enable=1
# opcache.memory_consumption=256
# opcache.interned_strings_buffer=16
# opcache.max_accelerated_files=10000
# opcache.validate_timestamps=0
# opcache.revalidate_freq=0
# opcache.save_comments=1
# opcache.fast_shutdown=1
#
# =================================================
