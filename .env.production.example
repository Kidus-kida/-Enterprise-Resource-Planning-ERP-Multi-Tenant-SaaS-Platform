# =================================================
# PRODUCTION ENVIRONMENT CONFIGURATION
# =================================================
# Copy this file to .env for production deployment
# Make sure to update all placeholders with actual values
# Never commit .env file to version control!
# =================================================

# =================================================
# APPLICATION CONFIGURATION
# =================================================
APP_NAME="TewosHR"
APP_ENV=production
APP_KEY=
# ⚠️ IMPORTANT: Generate with: php artisan key:generate

APP_DEBUG=false
# ⚠️ NEVER set to true in production!

APP_TIMEZONE=Africa/Nairobi
APP_URL=https://your-production-domain.com

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

# =================================================
# LOGGING CONFIGURATION
# =================================================
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error
# Use 'error' or 'warning' in production, not 'debug'

# =================================================
# DATABASE CONFIGURATION
# =================================================
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=your_production_database
DB_USERNAME=your_production_username
DB_PASSWORD=your_secure_password
# ⚠️ Use strong passwords in production!

# =================================================
# SESSION CONFIGURATION
# =================================================
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
# ⚠️ Enable encryption in production!
SESSION_PATH=/
SESSION_DOMAIN=null

# =================================================
# FILESYSTEM & QUEUE CONFIGURATION
# =================================================
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

# =================================================
# CACHE CONFIGURATION
# =================================================
CACHE_STORE=file
# Consider using 'redis' for better performance
CACHE_PREFIX=

# =================================================
# MEMCACHED CONFIGURATION
# =================================================
MEMCACHED_HOST=127.0.0.1

# =================================================
# REDIS CONFIGURATION (Optional - for caching/sessions)
# =================================================
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379
# Uncomment and configure if using Redis:
# CACHE_STORE=redis
# SESSION_DRIVER=redis

# =================================================
# MAIL CONFIGURATION
# =================================================
MAIL_MAILER=smtp
MAIL_HOST=your-mail-server.com
MAIL_PORT=587
MAIL_USERNAME='your-email@domain.com'
MAIL_PASSWORD='your-mail-password'
MAIL_ENCRYPTION=tls
# Use 'tls' for port 587, 'ssl' for port 465
MAIL_FROM_ADDRESS='noreply@your-domain.com'
MAIL_FROM_NAME="${APP_NAME}"

# =================================================
# AWS CONFIGURATION (Optional - for S3 storage)
# =================================================
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# =================================================
# VITE CONFIGURATION
# =================================================
VITE_APP_NAME="${APP_NAME}"

# =================================================
# REVERB CONFIGURATION (WebSocket Server)
# =================================================
REVERB_APP_ID="your_reverb_app_id"
REVERB_APP_KEY="your_reverb_app_key"
REVERB_APP_SECRET="your_reverb_app_secret"
REVERB_HOST="localhost"
REVERB_PORT=8080
REVERB_SCHEME=http
# For production with SSL, use https

# =================================================
# BROADCASTING & PUSHER CONFIGURATION
# =================================================
BROADCAST_CONNECTION=pusher
PUSHER_APP_KEY="your_pusher_app_key"
PUSHER_APP_SECRET="your_pusher_app_secret"
PUSHER_APP_ID="your_pusher_app_id"
PUSHER_APP_CLUSTER=ap2
VITE_PUSHER_APP_KEY="your_pusher_app_key"
VITE_PUSHER_APP_CLUSTER=ap2

# =================================================
# PRODUCTION DEPLOYMENT CHECKLIST
# =================================================
# After setting up your .env file, run these commands:
#
# 1. Generate application key:
#    php artisan key:generate
#
# 2. Run database migrations:
#    php artisan migrate --force
#
# 3. Cache configuration:
#    php artisan config:cache
#
# 4. Cache routes:
#    php artisan route:cache
#
# 5. Cache views:
#    php artisan view:cache
#
# 6. Optimize autoloader:
#    composer dump-autoload -o
#
# 7. Run Laravel optimize:
#    php artisan optimize
#
# 8. Build frontend assets:
#    npm run build
#
# 9. Set proper file permissions:
#    chmod -R 755 storage bootstrap/cache
#    chown -R www-data:www-data storage bootstrap/cache
#
# =================================================

# =================================================
# SECURITY RECOMMENDATIONS
# =================================================
# ✓ Set APP_DEBUG=false
# ✓ Use strong passwords for DB_PASSWORD
# ✓ Enable SESSION_ENCRYPT=true
# ✓ Use HTTPS (APP_URL should start with https://)
# ✓ Set LOG_LEVEL to 'error' or 'warning'
# ✓ Keep .env file secure and never commit it
# ✓ Use environment-specific mail credentials
# ✓ Configure firewall to restrict database access
# =================================================

# =================================================
# PHP.INI RECOMMENDATIONS (OPcache)
# =================================================
# Add these to your php.ini for better performance:
#
# opcache.enable=1
# opcache.memory_consumption=256
# opcache.interned_strings_buffer=16
# opcache.max_accelerated_files=10000
# opcache.validate_timestamps=0
# opcache.revalidate_freq=0
# opcache.save_comments=1
# opcache.fast_shutdown=1
# =================================================
